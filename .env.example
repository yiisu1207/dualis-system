# Dualis ERP — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env — it's in .gitignore.

# ─── EmailJS (client-side email sending) ────────────────────────
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_OTP_TEMPLATE=
VITE_EMAILJS_WELCOME_TEMPLATE=
VITE_EMAILJS_INVITE_TEMPLATE=

# ─── Firebase Cloud Messaging (push notifications) ─────────────
VITE_FIREBASE_VAPID_KEY=

# ─── ReCaptcha / Turnstile (optional, deferred to v1.1) ────────
VITE_RECAPTCHA_SITE_KEY=

# ─── Super Admin Panel ──────────────────────────────────────────
VITE_SUPER_ADMIN_PATH=ctrl-9x7b
VITE_SUPER_ADMIN_PIN=

# ─── Gemini AI (VisionLab, optional) ───────────────────────────
VITE_GEMINI_API_KEY=

# ─── Sentry (error tracking, optional) ─────────────────────────
VITE_SENTRY_DSN=

# ─── Notes ──────────────────────────────────────────────────────
# Firebase config (apiKey, authDomain, etc.) is hardcoded in
# src/firebase/config.ts — this is safe by design. Firebase API
# keys are NOT secrets; security comes from Firestore rules.
#
# Cloudinary cloud_name is also public (unsigned presets).
