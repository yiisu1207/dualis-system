rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // HELPERS
    function isSignedIn() {
      return request.auth != null;
    }

    // Super admin — acceso global de operaciones (email del panel ctrl-9x7b)
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'yisus_xd77@hotmail.com';
    }

    // Ops monitor — usuario anónimo con token válido
    function isOpsUser() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/opsTokens/$(request.auth.uid));
    }

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // El ID de empresa del usuario (soporta ambos esquemas)
    function myBID() {
      let data = getUser();
      return data.businessId != null ? data.businessId : data.empresa_id;
    }

    function myRole() {
      let data = getUser();
      return data.role != null ? data.role.lower() : 'pending';
    }

    // Es miembro si el ID del documento coincide con el ID del usuario
    function isMember(bid) {
      let me = myBID();
      return isSignedIn() && me != null && me == bid;
    }

    // Es admin si es miembro y tiene rol alto
    function isAdmin(bid) {
      let role = myRole();
      return isMember(bid) && (role == 'admin' || role == 'owner');
    }

    function isOwner(bid) {
      return isMember(bid) && myRole() == 'owner';
    }

    // Verificar si un documento pertenece a la empresa del usuario
    function belongsToMe(data) {
      let me = myBID();
      return isSignedIn() && me != null && (data.businessId == me || data.empresa_id == me);
    }

    // ─── REGLAS ─────────────────────────────────────────────────────────────

    // OPS TOKENS (sesiones de monitoreo anónimas)
    match /opsTokens/{tokenId} {
      // El propio usuario anónimo puede crear/leer/actualizar/borrar su token
      allow read, create, update, delete: if isSignedIn() && request.auth.uid == tokenId;
      // Super admin puede limpiar tokens
      allow read, delete: if isSuperAdmin();
    }

    // PERFILES DE USUARIO
    match /users/{uid} {
      // Ops monitor puede leer todos los perfiles (read-only)
      allow read: if isOpsUser();
      // Super admin puede leer/escribir cualquier perfil (para activar cuentas pendientes)
      allow read, write: if isSuperAdmin();
      allow read, write: if isSignedIn() && request.auth.uid == uid;
      allow read: if isSignedIn() && belongsToMe(resource.data);
      allow update, delete: if isSignedIn() && belongsToMe(resource.data) && (myRole() == 'admin' || myRole() == 'owner');
    }

    // RAMA DE NEGOCIO (Contenedor central)
    match /businesses/{bid} {
      // Ops monitor puede listar negocios (read-only)
      allow read: if isOpsUser();
      allow read, write: if isSuperAdmin();
      // Permitir get (lectura por ID exacto) a cualquiera.
      // El businessId es un secreto criptográfico de 32 chars (key_XXX),
      // así que conocerlo equivale a haber sido invitado.
      // Esto permite validar workspace code durante registro (join mode)
      // antes de que el usuario esté autenticado.
      allow get: if true;
      allow read: if isMember(bid);
      // Permite crear el negocio si el usuario autenticado es el ownerId del documento (registro inicial)
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow write: if isAdmin(bid);

      // Productos: ventas puede actualizar (para descontar stock en POS)
      match /products/{productId} {
        allow read: if isMember(bid);
        allow create, delete: if isAdmin(bid);
        allow update: if isMember(bid);
      }

      // Terminales: ventas puede actualizar estadísticas al procesar venta
      match /terminals/{terminalId} {
        allow read: if isMember(bid);
        allow create, delete: if isAdmin(bid);
        allow update: if isMember(bid);
      }

      // Vales (vouchers): cualquier miembro puede registrar y leer
      match /vouchers/{docId} {
        allow read: if isMember(bid);
        allow create: if isMember(bid);
        allow update: if isMember(bid);
        allow delete: if isAdmin(bid);
      }

      // Time entries (overtime/absences/missing days): cualquier miembro
      match /time_entries/{docId} {
        allow read: if isMember(bid);
        allow create: if isMember(bid);
        allow update: if isMember(bid);
        allow delete: if isAdmin(bid);
      }

      // Préstamos: cualquier miembro puede registrar
      match /loans/{docId} {
        allow read: if isMember(bid);
        allow create: if isMember(bid);
        allow update: if isMember(bid);
        allow delete: if isAdmin(bid);
      }

      // Adelantos de nómina: cualquier miembro puede registrar
      match /payroll_advances/{docId} {
        allow read: if isMember(bid);
        allow create: if isMember(bid);
        allow update: if isMember(bid);
        allow delete: if isAdmin(bid);
      }

      // Comentarios de comparación de vales: cualquier miembro puede leer/crear
      match /voucher_compare_comments/{docId} {
        allow read: if isMember(bid);
        allow create: if isMember(bid);
        allow update: if isMember(bid) && request.auth.uid == resource.data.authorId;
        allow delete: if isAdmin(bid);
      }

      // Chat: todos los miembros pueden crear canales y enviar mensajes
      match /conversations/{convId} {
        allow read:   if isMember(bid);
        allow create: if isMember(bid);
        allow update: if isMember(bid);
        match /messages/{msgId} {
          allow read:          if isMember(bid);
          allow create:        if isMember(bid);
          allow update, delete: if isMember(bid) && request.auth.uid == resource.data.senderId;
        }
        match /typing/{userId} {
          allow read, write: if isMember(bid);
        }
        match /reads/{userId} {
          allow read, write: if isMember(bid);
        }
      }

      // Empleados: cualquier miembro puede leer/crear/actualizar
      match /employees/{docId} {
        allow read: if isMember(bid);
        allow create, update: if isMember(bid);
        allow delete: if isAdmin(bid);
      }

      // Tasas de vales: cualquier miembro puede leer/crear
      match /voucher_rates/{docId} {
        allow read: if isMember(bid);
        allow create: if isMember(bid);
        allow update, delete: if isAdmin(bid);
      }

      // Payroll runs: cualquier miembro puede leer/crear (procesar nómina)
      match /payroll_runs/{docId} {
        allow read: if isMember(bid);
        allow create: if isMember(bid);
        allow update: if isMember(bid);
        allow delete: if isAdmin(bid);
      }

      // Solicitudes de abono: vendedor crea, admin aprueba/rechaza
      match /paymentRequests/{reqId} {
        allow read: if isMember(bid);
        allow create: if isMember(bid);
        allow update: if isAdmin(bid);
        allow delete: if isAdmin(bid);
      }

      // Portal de Clientes — acceso público por token
      match /portalAccess/{tokenId} {
        // Público: clientes validan su token + PIN sin auth
        allow get: if true;
        // Solo admin puede gestionar accesos
        allow list, create, update, delete: if isAdmin(bid);
      }

      // Pagos enviados desde el Portal de Clientes
      match /portalPayments/{payId} {
        // Público: clientes crean pagos (validación por token en app)
        allow create: if true;
        // Miembros pueden leer; admin puede aprobar/rechazar
        allow read: if isMember(bid);
        allow update: if isAdmin(bid);
        allow delete: if isAdmin(bid);
      }

      // Catch-all: cualquier subcollection NO listada arriba
      // Miembros pueden leer y crear/actualizar; solo admin puede borrar
      match /{allSubcollections=**} {
        allow read: if isMember(bid);
        allow create, update: if isMember(bid);
        allow delete: if isAdmin(bid);
      }
    }

    // CONFIGURACIONES (solo admin puede escribir)
    match /businessConfigs/{bid} {
      allow read: if isMember(bid);
      allow write: if isAdmin(bid);

      match /{allSubcollections=**} {
        allow read: if isMember(bid);
        allow write: if isAdmin(bid);
      }
    }

    // PERSONALIZACIONES POR EMPRESA (super-admin panel)
    // Solo el super-admin escribe. El admin/owner de la empresa puede leer su propia config.
    match /vendorOverrides/{bid} {
      allow read: if isSuperAdmin() || isAdmin(bid);
      allow write: if isSuperAdmin();
    }

    // EVENTOS EXTERNOS (recibidos por Cloud Functions — solo lectura para super-admin)
    match /externalEvents/{docId} {
      allow read: if isSuperAdmin();
      allow write: if false; // solo Cloud Functions via Admin SDK
    }

    // SUBSCRIPCIONES
    match /subscriptions/{docId} {
      allow read: if isSuperAdmin() || (isSignedIn() && belongsToMe(resource.data));
      allow write: if isSuperAdmin();
    }

    // COLECCIONES OPERATIVAS EN RAÍZ
    // (movements, customers, suppliers, auditLogs, etc.)
    // Cualquier miembro puede leer, crear y actualizar; solo admin puede borrar
    match /{collectionName}/{docId} {
      allow read: if isSignedIn() && belongsToMe(resource.data);
      allow create: if isSignedIn() && belongsToMe(request.resource.data);
      allow update: if isSignedIn() && belongsToMe(resource.data);
      allow delete: if isSignedIn() && belongsToMe(resource.data) && (myRole() == 'admin' || myRole() == 'owner');
    }

    // INVITACIONES (root mirror para lookup por token)
    match /invitations/{token} {
      // Cualquier usuario puede leer una invitación por token (para validar en /join)
      allow get: if true;
      // Solo el owner del negocio puede crear invitaciones
      allow create: if isSignedIn() && isOwner(request.resource.data.businessId);
      // Consumir invitación: cualquier usuario autenticado (al registrarse)
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // COMPARAR LIBROS — solicitudes
    // Queries use single where('receiverId'==uid) or where('requesterId'==uid),
    // so rules must match without requiring businessId in query constraints.
    match /bookCompareRequests/{docId} {
      allow read: if isSignedIn() && (
        resource.data.receiverId == request.auth.uid ||
        resource.data.requesterId == request.auth.uid ||
        belongsToMe(resource.data)
      );
      allow create: if isSignedIn() && belongsToMe(request.resource.data);
      // El receptor puede aceptar/rechazar; el solicitante puede cancelar/cerrar; admin siempre
      allow update: if isSignedIn() && (
        resource.data.receiverId == request.auth.uid ||
        resource.data.requesterId == request.auth.uid ||
        (belongsToMe(resource.data) && (myRole() == 'admin' || myRole() == 'owner'))
      );
    }

    // COMPARAR LIBROS — chat de sesión
    // Query by requestId only — allow any authenticated user (requestId is opaque/random)
    match /bookCompareChats/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && belongsToMe(request.resource.data);
    }

    // COMPARAR LIBROS — notas por fila
    match /bookCompareNotes/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && belongsToMe(request.resource.data);
    }

    // TENANTS (subdomain multi-tenancy: slug → businessId)
    match /tenants/{slug} {
      // Público: cualquier persona puede resolver un slug para login
      allow get: if true;
      // Solo listar si es super-admin u ops monitor (para auditoría)
      allow list: if isSuperAdmin() || isOpsUser();
      // Super-admin o admin/owner del negocio puede crear/actualizar su slug
      allow create: if isSuperAdmin() || (isSignedIn() && isAdmin(request.resource.data.businessId));
      allow update: if isSuperAdmin() || (isSignedIn() && isAdmin(resource.data.businessId));
      // Solo super-admin puede eliminar
      allow delete: if isSuperAdmin();
    }

    // SOLICITUDES
    match /workspaceRequests/{docId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (request.auth.uid == resource.data.senderId || (resource.data.workspaceId != null && isAdmin(resource.data.workspaceId)));
      allow update: if isSignedIn() && resource.data.workspaceId != null && isAdmin(resource.data.workspaceId);
    }
  }
}
